#!/usr/bin/env bash
# Pre-commit hook for assisted-review. Runs the test suite; aborts the commit
# on failure. Set up once with:
#
#     git config core.hooksPath hooks
#
# To bypass intentionally (rare): git commit --no-verify

set -uo pipefail
REPO_ROOT="$(git rev-parse --show-toplevel)"
TESTS="$REPO_ROOT/tests/run.sh"

if [ ! -x "$TESTS" ]; then
    echo "pre-commit: tests/run.sh missing or not executable; skipping" >&2
    exit 0
fi

echo "pre-commit: running tests/run.sh"
if ! "$TESTS" >/tmp/assisted-review-pre-commit.log 2>&1; then
    echo "pre-commit: tests FAILED — aborting commit" >&2
    echo >&2
    tail -40 /tmp/assisted-review-pre-commit.log >&2
    echo >&2
    echo "Full log: /tmp/assisted-review-pre-commit.log" >&2
    exit 1
fi

echo "pre-commit: tests passed"
exit 0
